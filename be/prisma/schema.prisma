generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(STAFF)
  phone     String?
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  inbounds                Inbound[]
  outboundPickings        Outbound[]
  packings                Packing[]
  sortings                Sorting[]
  shipments               Shipment[]
  inventoryChecks         InventoryCheck[]        @relation("InventoryCheckChecker")
  inventoryCheckApprovals InventoryCheck[]        @relation("InventoryCheckApprover")
  approvalsGiven          PurchaseOrderApproval[] @relation("approver")
  inventoryMovements      InventoryMovement[]
  phieuNhapKho            PhieuNhapKho[]          @relation("PhieuNhapKhoCreator")
  phieuXuatKho            PhieuXuatKho[]

  // Transfer relations
  requestedTransfers Transfer[]               @relation("TransferRequester")
  approvedTransfers  Transfer[]               @relation("TransferApprover")
  cancelledTransfers Transfer[]               @relation("TransferCanceller")
  resolvedTransfers  TransferReconciliation[]
  generatedReports   MonthlyReportSnapshot[]
}

enum UserRole {
  ADMIN
  QUALITY
  ACCOUNTING
  WAREHOUSE_DIRECTOR
  STAFF
  DRIVER
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  orderNumber  String              @unique
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  status       PurchaseOrderStatus @default(DRAFT)
  expectedDate DateTime?
  notes        String?
  createdById  String
  createdBy    User                @relation(fields: [createdById], references: [id])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  approvals PurchaseOrderApproval[]
  inbound   Inbound?
  items     PurchaseOrderItem[]
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_ACCOUNTING
  PENDING_APPROVAL
  APPROVED
  SENT_TO_SUPPLIER
  SUPPLIER_CONFIRMED
  SUPPLIER_REJECTED
  CANCELLED
  COMPLETED
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  receivedQty     Int           @default(0)
  createdAt       DateTime      @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model PurchaseOrderApproval {
  id              String         @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  approverId      String
  approver        User           @relation("approver", fields: [approverId], references: [id])
  role            ApprovalRole
  status          ApprovalStatus
  notes           String?
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
}

enum ApprovalRole {
  ACCOUNTING
  WAREHOUSE_DIRECTOR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Inbound {
  id              String         @id @default(cuid())
  inboundNumber   String         @unique
  purchaseOrderId String?        @unique
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  staffId         String
  staff           User           @relation(fields: [staffId], references: [id])
  status          InboundStatus  @default(INBOUND_CREATED)
  receivedDate    DateTime?
  qcPassedDate    DateTime?
  completedDate   DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items        InboundItem[]
  PhieuNhapKho PhieuNhapKho?
}

enum InboundStatus {
  INBOUND_CREATED
  ITEMS_RECEIVED
  QUALITY_CHECKING
  QC_PASSED
  QC_FAILED
  BARCODE_CREATED
  LOCATION_ASSIGNED
  STAFF_RECEIVED
  NEW_PRODUCT_CREATED
  INVENTORY_UPDATED
  INBOUND_COMPLETED
  INBOUND_CANCELLED
}

model InboundItem {
  id          String             @id @default(cuid())
  inboundId   String
  inbound     Inbound            @relation(fields: [inboundId], references: [id])
  productId   String
  product     Product            @relation(fields: [productId], references: [id])
  quantity    Int
  receivedQty Int                @default(0)
  damageQty   Int                @default(0)
  barcode     String?            @unique
  locationId  String?
  location    WarehouseLocation? @relation(fields: [locationId], references: [id])
  notes       String?
  createdAt   DateTime           @default(now())
}

model Outbound {
  id             String         @id @default(cuid())
  outboundNumber String         @unique
  orderRef       String?        @unique
  status         OutboundStatus @default(ORDER_RECEIVED)
  pickerId       String
  picker         User           @relation(fields: [pickerId], references: [id])
  pickedDate     DateTime?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  items        OutboundItem[]
  packing      Packing?
  phieuXuatKho PhieuXuatKho?
}

model PhieuNhapKho {
  id             String        @id @default(cuid())
  phieuNumber    String        @unique
  inboundId      String        @unique
  inbound        Inbound       @relation(fields: [inboundId], references: [id])
  createdById    String?
  createdBy      User?         @relation("PhieuNhapKhoCreator", fields: [createdById], references: [id])
  notes          String?
  createdAt      DateTime      @default(now())

  @@map("phieu_nhap_kho")
}

model PhieuXuatKho {
  id          String   @id @default(cuid())
  phieuNumber String   @unique
  outboundId  String   @unique
  outbound    Outbound @relation(fields: [outboundId], references: [id])
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  notes       String?
  createdAt   DateTime @default(now())
}

enum OutboundStatus {
  ORDER_RECEIVED
  INVENTORY_CHECKED
  INVENTORY_SUFFICIENT
  INVENTORY_INSUFFICIENT
  PICKING_ASSIGNED
  PICKER_ASSIGNED
  ITEM_SCANNED
  PICKED_CORRECT
  PICKED_WRONG
  PUT_IN_CART
  SLIP_PRINTED
  MOVED_TO_PACKING
}

model OutboundItem {
  id         String             @id @default(cuid())
  outboundId String
  outbound   Outbound           @relation(fields: [outboundId], references: [id])
  productId  String
  product    Product            @relation(fields: [productId], references: [id])
  quantity   Int
  pickedQty  Int                @default(0)
  locationId String?
  location   WarehouseLocation? @relation(fields: [locationId], references: [id])
  createdAt  DateTime           @default(now())
}

model Packing {
  id            String        @id @default(cuid())
  packingNumber String        @unique
  outboundId    String        @unique
  outbound      Outbound      @relation(fields: [outboundId], references: [id])
  packerId      String
  packer        User          @relation(fields: [packerId], references: [id])
  status        PackingStatus @default(PENDING)
  packedDate    DateTime?
  sealedDate    DateTime?
  weight        Float?
  dimension     String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sorting Sorting?

  // Grouping fields for carton/pallet management
  cartonId    String?
  palletId    String?
  itemsPacked Int     @default(0)
}

enum PackingStatus {
  PENDING
  PACKING
  PACKED
  SEALED
  ON_CONVEYOR
  CANCELLED
}

model Sorting {
  id            String        @id @default(cuid())
  sortingNumber String        @unique
  packingId     String        @unique
  packing       Packing       @relation(fields: [packingId], references: [id])
  sorterId      String
  sorter        User          @relation(fields: [sorterId], references: [id])
  status        SortingStatus @default(PENDING)
  sortedDate    DateTime?
  completedDate DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  shipment Shipment?
}

enum SortingStatus {
  PENDING
  SORTING
  SORTED
  COMPLETED
}

// Internal transfer between warehouse locations
model Transfer {
  id             String            @id @default(cuid())
  transferNumber String            @unique
  fromLocationId String
  fromLocation   WarehouseLocation @relation("TransferFromLocation", fields: [fromLocationId], references: [id])
  toLocationId   String
  toLocation     WarehouseLocation @relation("TransferToLocation", fields: [toLocationId], references: [id])
  status         TransferStatus    @default(PENDING)
  requestedById  String
  requestedBy    User              @relation("TransferRequester", fields: [requestedById], references: [id])
  approvedById   String?
  approvedBy     User?             @relation("TransferApprover", fields: [approvedById], references: [id])
  dispatchedAt   DateTime?
  receivedAt     DateTime?
  cancelledAt    DateTime?
  cancelledById  String?
  cancelledBy    User?             @relation("TransferCanceller", fields: [cancelledById], references: [id])
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  items           TransferItem[]
  reconciliations TransferReconciliation[]
}

enum TransferStatus {
  PENDING // Transfer requested, awaiting approval
  APPROVED // Transfer approved, ready for dispatch
  DISPATCHED // Items dispatched from source (paired movement recorded)
  IN_TRANSIT // Items in transit
  RECEIVED // Items received at destination (paired movement recorded)
  COMPLETED // Transfer fully completed
  CANCELLED // Transfer cancelled
  EXCEPTION // Transfer has discrepancy requiring reconciliation
}

model TransferItem {
  id          String   @id @default(cuid())
  transferId  String
  transfer    Transfer @relation(fields: [transferId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  receivedQty Int      @default(0)
  createdAt   DateTime @default(now())

  // Reconciliation for discrepancies
  discrepancyNote String?
  resolved        Boolean @default(false)
}

// Reconciliation task created when transfer has discrepancy
model TransferReconciliation {
  id             String    @id @default(cuid())
  transferId     String
  transfer       Transfer  @relation(fields: [transferId], references: [id])
  productId      String
  product        Product   @relation(fields: [productId], references: [id])
  expectedQty    Int
  actualQty      Int
  discrepancyQty Int
  resolvedById   String?
  resolvedBy     User?     @relation(fields: [resolvedById], references: [id])
  resolvedAt     DateTime?
  resolution     String? // RESOLVED_SOURCE, RESOLVED_DESTINATION, WRITTEN_OFF
  notes          String?
  createdAt      DateTime  @default(now())
}

model Shipment {
  id             String         @id @default(cuid())
  shipmentNumber String         @unique
  sortingId      String         @unique
  sorting        Sorting        @relation(fields: [sortingId], references: [id])
  shipperId      String
  shipper        User           @relation(fields: [shipperId], references: [id])
  carrier        String
  trackingNumber String?        @unique
  status         ShipmentStatus @default(CREATED)
  shippedDate    DateTime?
  deliveredDate  DateTime?
  deliveryNotes  String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum ShipmentStatus {
  CREATED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

model InventoryCheck {
  id          String               @id @default(cuid())
  checkNumber String               @unique
  checkerId   String
  checker     User                 @relation("InventoryCheckChecker", fields: [checkerId], references: [id])
  type        InventoryCheckType   @default(ROUTINE)
  startDate   DateTime?
  endDate     DateTime?
  status      InventoryCheckStatus @default(PENDING)
  notes       String?
  scope       String?
  approverId  String?
  approver    User?                @relation("InventoryCheckApprover", fields: [approverId], references: [id])
  approvedAt  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  items InventoryCheckItem[]
}

enum InventoryCheckType {
  ROUTINE
  SPOT_CHECK
  ANNUAL
}

enum InventoryCheckStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model InventoryCheckItem {
  id               String         @id @default(cuid())
  inventoryCheckId String
  inventoryCheck   InventoryCheck @relation(fields: [inventoryCheckId], references: [id])
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  systemQty        Int
  actualQty        Int
  discrepancy      Int
  notes            String?
  createdAt        DateTime       @default(now())
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  category    String?
  unit        String   @default("piece")
  weight      Float?
  dimensions  String?
  price       Float    @default(0)
  minStock    Int      @default(10)
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrderItems      PurchaseOrderItem[]
  inboundItems            InboundItem[]
  outboundItems           OutboundItem[]
  inventory               Inventory?
  inventoryCheckItems     InventoryCheckItem[]
  inventoryMovements      InventoryMovement[]
  transferItems           TransferItem[]
  transferReconciliations TransferReconciliation[]
  reportSnapshots         MonthlyReportSnapshot[]
}

model WarehouseLocation {
  id        String   @id @default(cuid())
  zone      String
  row       Int
  shelf     Int
  position  Int?
  capacity  Int      @default(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  inboundItems  InboundItem[]
  outboundItems OutboundItem[]
  fromMovements InventoryMovement[] @relation("FromLocation")
  toMovements   InventoryMovement[] @relation("ToLocation")

  // Transfer relations
  transfersFrom Transfer[] @relation("TransferFromLocation")
  transfersTo   Transfer[] @relation("TransferToLocation")

  // Report relations
  reportSnapshots MonthlyReportSnapshot[]
}

enum MovementType {
  INBOUND
  OUTBOUND
  RESERVATION
  RELEASE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  DAMAGED
  RETURNED
}

model InventoryMovement {
  id             String             @id @default(cuid())
  productId      String
  product        Product            @relation(fields: [productId], references: [id])
  movementType   MovementType
  quantity       Int
  referenceType  String
  referenceId    String
  fromLocationId String?
  fromLocation   WarehouseLocation? @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocationId   String?
  toLocation     WarehouseLocation? @relation("ToLocation", fields: [toLocationId], references: [id])
  notes          String?
  createdById    String?
  createdBy      User?              @relation(fields: [createdById], references: [id])
  createdAt      DateTime           @default(now())
}

model MonthlyReportSnapshot {
  id                  String             @id @default(cuid())
  reportKey           String             @unique
  reportType          String             @default("MONTHLY_INVENTORY")
  periodKey           String
  periodStart         DateTime
  periodEnd           DateTime
  closedAt            DateTime
  warehouseLocationId String?
  warehouseLocation   WarehouseLocation? @relation(fields: [warehouseLocationId], references: [id], onDelete: SetNull)
  productId           String?
  product             Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  category            String?
  closeRule           String
  sourceHash          String
  sourceMovementCount Int
  payload             Json
  generatedById       String?
  generatedBy         User?              @relation(fields: [generatedById], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([periodKey])
  @@index([sourceHash])
  @@index([warehouseLocationId])
  @@index([productId])
}

model Inventory {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(0)
  available Int      @default(0)
  reserved  Int      @default(0)
  costPrice Float    @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model EventLog {
  id         String   @id @default(cuid())
  eventType  String
  process    String
  entityType String
  entityId   String
  userId     String?
  payload    Json?
  status     String   @default("SUCCESS")
  errorMsg   String?
  createdAt  DateTime @default(now())
}

model Outbox {
  id         String   @id @default(cuid())
  eventType  String
  entityType String
  entityId   String
  payload    Json
  status     String   @default("PENDING")
  attempts   Int      @default(0)
  lastError  String?
  lockedAt   DateTime?
  processedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, createdAt])
  @@index([entityType, entityId])
}
